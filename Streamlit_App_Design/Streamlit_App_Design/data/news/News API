"""
================================================================================
hydrogen_news_mediastack.py
================================================================================
 
Purpose:
    Fetches today's hydrogen-related news articles from the Mediastack API.
    Only articles published on the current day (UTC) are returned.
    This module provides a single fetch function and does NOT run any request
    automatically -- it must be called explicitly by the application.
 
API:
    Provider : Mediastack (https://api.mediastack.com)
    Endpoint : GET /v1/news
    Auth     : access_key query parameter
 
Requirements:
    pip install requests
 
Usage:
    from hydrogen_news_mediastack import fetch_hydrogen_news_today
 
    for keyword in BUZZWORDS:
        result = fetch_hydrogen_news_today(keyword)
        print(result)
================================================================================
"""
 
import requests
from datetime import datetime, timezone
 
 
# ==============================================================================
# CONFIGURATION
# ==============================================================================
 
# Mediastack API access key -- unique per account, do not share publicly.
API_KEY = "cfd9b9b3f23e9a769b6725c0f7bc480c"
 
# Base URL of the Mediastack live news endpoint.
MEDIASTACK_URL = "https://api.mediastack.com/v1/news"
 
# Search terms used to query hydrogen-related news articles.
# Each keyword targets a different aspect of the hydrogen market:
#   - Price and supply signals  (e.g. electricity price, surplus generation)
#   - Demand and trade signals  (e.g. import terminals, trade deals in Asia)
BUZZWORDS = [
    "green hydrogen import",          # Import of green hydrogen
    "hydrogen economy Asia",          # Hydrogen economy in Asia
    "electricity price hydrogen",     # Electricity prices linked to hydrogen
    "excess generation electrolyzer", # Surplus power used for electrolysis
    "hydrogen terminal Japan",        # Hydrogen import terminal in Japan
    "ammonia port Korea",             # Ammonia port activity in South Korea
    "electrolyzer order Korea",       # Electrolyzer procurement in Korea
    "hydrogen plant Asia Pacific",    # Hydrogen facilities in the Asia-Pacific region
    "hydrogen MOU ministry",          # Government memoranda of understanding
    "hydrogen trade deal",            # International hydrogen trade agreements
    "renewable surplus hydrogen",     # Hydrogen from renewable energy surplus
    "variable renewable hydrogen",    # Hydrogen from variable renewable sources
]
 
 
# ==============================================================================
# FETCH FUNCTION
# ==============================================================================
 
def fetch_hydrogen_news_today(keyword: str, max_results: int = 10) -> dict:
    """
    Fetches news articles from the Mediastack API for a single keyword,
    filtered to today's date only (UTC).
 
    The function builds a GET request with the following parameters:
      - access_key : API authentication key
      - keywords   : the search term to filter articles
      - languages  : restricted to English ("en")
      - date       : today's date in YYYY-MM-DD format (UTC)
      - sort       : newest articles first ("published_desc")
      - limit      : maximum number of results (default 10, max 100)
 
    Parameters:
        keyword (str):     The search term to query (one entry from BUZZWORDS).
        max_results (int): Number of articles to retrieve per request.
                           Default is 10. Maximum allowed by the API is 100.
 
    Returns:
        dict with the following keys:
            "keyword"  -> the search term that was used
            "date"     -> the date that was queried (YYYY-MM-DD, UTC)
            "articles" -> list of article dicts, each containing:
                            "title"        -> headline of the article
                            "source"       -> name of the news source
                            "published_at" -> publication timestamp (string)
                            "url"          -> direct link to the article
            "error"    -> error message string (only present if request failed)
    """
    # Determine today's date in UTC (YYYY-MM-DD), as required by the API's
    # "date" parameter. Using UTC ensures consistency regardless of the local
    # timezone of the machine running the script.
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
 
    # Build the query parameters according to the Mediastack API documentation.
    params = {
        "access_key": API_KEY,
        "keywords":   keyword,       # Full-text keyword search
        "languages":  "en",          # English articles only
        "date":       today,         # Restrict to today's publications
        "sort":       "published_desc",  # Newest articles first
        "limit":      max_results,   # Number of results (default 10, max 100)
    }
 
    try:
        # Send the GET request with a 10-second timeout to avoid hanging.
        response = requests.get(MEDIASTACK_URL, params=params, timeout=10)
 
        # Raise an exception immediately if the HTTP status code signals an error
        # (e.g. 401 Unauthorized, 429 Too Many Requests, 500 Server Error).
        response.raise_for_status()
 
        # Parse the JSON body of the response into a Python dictionary.
        raw = response.json()
 
        # Extract the "data" list from the response. Each entry represents one
        # article. If the field is missing, fall back to an empty list.
        articles = []
        for entry in raw.get("data", []):
            articles.append({
                "title":        entry.get("title"),
                "source":       entry.get("source"),
                "published_at": entry.get("published_at"),
                "url":          entry.get("url"),
            })
 
        return {
            "keyword":  keyword,
            "date":     today,
            "articles": articles,
        }
 
    except requests.exceptions.HTTPError as e:
        # The server returned an error status code (4xx or 5xx).
        return {"keyword": keyword, "date": today, "error": f"HTTP error: {e}"}
 
    except requests.exceptions.ConnectionError:
        # The network is unreachable or the hostname could not be resolved.
        return {"keyword": keyword, "date": today, "error": "Connection error: could not reach Mediastack API"}
 
    except requests.exceptions.Timeout:
        # The server did not respond within 10 seconds.
        return {"keyword": keyword, "date": today, "error": "Request timed out after 10 seconds"}
 
    except Exception as e:
        # Catch-all for unexpected errors (e.g. malformed JSON, parsing issues).
        return {"keyword": keyword, "date": today, "error": str(e)}
